> </ul> <ol> <li> <p>\u6cd5\u8bed\u53d1\u97f3\u7c7b\u4f3cDom\u00a0\u21a9</p> </li> <li> <p>\u6ce8\u610f\uff01\u53e4\u733f\u7684\u884c\u4e3a\u662f\u8fdd\u6cd5\u884c\u4e3a\uff0c\u8bf7\u52ff\u6a21\u4eff\uff01\u8fdd\u53cd\u4e86\u2460\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u5baa\u6cd5\u300b\u7b2c\u4e09\u5341\u516b\u6761 \u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u516c\u6c11\u7684\u4eba\u683c\u5c0a\u4e25\u4e0d\u53d7\u4fb5\u72af\u3002\u7981\u6b62\u7528\u4efb\u4f55\u65b9\u6cd5\u5bf9\u516c\u6c11\u8fdb\u884c\u4fae\u8fb1\u3001\u8bfd\u8c24\u548c\u8bec\u544a\u9677\u5bb3\u3002 \u2461\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6c11\u6cd5\u5178\u300b\u7b2c\u4e00\u5343\u96f6\u4e8c\u5341\u56db\u6761 \u6c11\u4e8b\u4e3b\u4f53\u4eab\u6709\u540d\u8a89\u6743\u3002\u4efb\u4f55\u7ec4\u7ec7\u6216\u8005\u4e2a\u4eba\u4e0d\u5f97\u4ee5\u4fae\u8fb1\u3001\u8bfd\u8c24\u7b49\u65b9\u5f0f\u4fb5\u5bb3\u4ed6\u4eba\u7684\u540d\u8a89\u6743\u3002 \u2462\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u6cbb\u5b89\u7ba1\u7406\u5904\u7f5a\u6cd5\u300b\u7b2c\u56db\u5341\u4e8c\u6761 \u6709\u4e0b\u5217\u884c\u4e3a\u4e4b\u4e00\u7684\uff0c\u5904\u4e94\u65e5\u4ee5\u4e0b\u62d8\u7559\u6216\u8005\u4e94\u767e\u5143\u4ee5\u4e0b\u7f5a\u6b3e\uff1b\u60c5\u8282\u8f83\u91cd\u7684\uff0c\u5904\u4e94\u65e5\u4ee5\u4e0a\u5341\u65e5\u4ee5\u4e0b\u62d8\u7559\uff0c\u53ef\u4ee5\u5e76\u5904\u4e94\u767e\u5143\u4ee5\u4e0b\u7f5a\u6b3e\uff1a\uff08\u4e00\uff09\u5199\u6050\u5413\u4fe1\u6216\u8005\u4ee5\u5176\u4ed6\u65b9\u6cd5\u5a01\u80c1\u4ed6\u4eba\u4eba\u8eab\u5b89\u5168\u7684\uff1b\uff08\u4e8c\uff09\u516c\u7136\u4fae\u8fb1\u4ed6\u4eba\u6216\u8005\u634f\u9020\u4e8b\u5b9e\u8bfd\u8c24\u4ed6\u4eba\u7684\uff1b\uff08\u4e09\uff09\u634f\u9020\u4e8b\u5b9e\u8bec\u544a\u9677\u5bb3\u4ed6\u4eba\uff0c\u4f01\u56fe\u4f7f\u4ed6\u4eba\u53d7\u5230\u5211\u4e8b\u8ffd\u7a76\u6216\u8005\u53d7\u5230\u6cbb\u5b89\u7ba1\u7406\u5904\u7f5a\u7684\uff1b\uff08\u56db\uff09\u5bf9\u8bc1\u4eba\u53ca\u5176\u8fd1\u4eb2\u5c5e\u8fdb\u884c\u5a01\u80c1\u3001\u4fae\u8fb1\u3001\u6bb4\u6253\u6216\u8005\u6253\u51fb\u62a5\u590d\u7684\uff1b\uff08\u4e94\uff09\u591a\u6b21\u53d1\u9001\u6deb\u79fd\u3001\u4fae\u8fb1\u3001\u6050\u5413\u6216\u8005\u5176\u4ed6\u4fe1\u606f\uff0c\u5e72\u6270\u4ed6\u4eba\u6b63\u5e38\u751f\u6d3b\u7684\uff1b\uff08\u516d\uff09\u5077\u7aa5\u3001\u5077\u62cd\u3001\u7a83\u542c\u3001\u6563\u5e03\u4ed6\u4eba\u9690\u79c1\u7684\u3002 \u2463\u300a\u4e2d\u534e\u4eba\u6c11\u5171\u548c\u56fd\u5211\u6cd5\u300b\u7b2c\u4e8c\u767e\u56db\u5341\u516d\u6761 \u3010\u4fae\u8fb1\u7f6a\u3001\u8bfd\u8c24\u7f6a\u3011\u4ee5\u66b4\u529b\u6216\u8005\u5176\u4ed6\u65b9\u6cd5\u516c\u7136\u4fae\u8fb1\u4ed6\u4eba\u6216\u8005\u634f\u9020\u4e8b\u5b9e\u8bfd\u8c24\u4ed6\u4eba\uff0c\u60c5\u8282\u4e25\u91cd\u7684\uff0c\u5904\u4e09\u5e74\u4ee5\u4e0b\u6709\u671f\u5f92\u5211\u3001\u62d8\u5f79\u3001\u7ba1\u5236\u6216\u8005\u5265\u593a\u653f\u6cbb\u6743\u5229\u3002\u524d\u6b3e\u7f6a\uff0c\u544a\u8bc9\u7684\u624d\u5904\u7406\uff0c\u4f46\u662f\u4e25\u91cd\u5371\u5bb3\u793e\u4f1a\u79e9\u5e8f\u548c\u56fd\u5bb6\u5229\u76ca\u7684\u9664\u5916\u3002\u901a\u8fc7\u4fe1\u606f\u7f51\u7edc\u5b9e\u65bd\u7b2c\u4e00\u6b3e\u89c4\u5b9a\u7684\u884c\u4e3a\uff0c\u88ab\u5bb3\u4eba\u5411\u4eba\u6c11\u6cd5\u9662\u544a\u8bc9\uff0c\u4f46\u63d0\u4f9b\u8bc1\u636e\u786e\u6709\u56f0\u96be\u7684\uff0c\u4eba\u6c11\u6cd5\u9662\u53ef\u4ee5\u8981\u6c42\u516c\u5b89\u673a\u5173\u63d0\u4f9b\u534f\u52a9\u3002 \u21a9</p> </li> <li> <p>\u65e0\u4fae\u8fb1\u6027\u00a0\u21a9</p> </li> <li> <p>\u6d77\u54e5\u6700\u8fd1\u8bf4\u5b83\u201c\u5fc3\u667a\u3001\u884c\u4e3a\u6bd4\u4ee5\u524d\u6210\u719f\u3002\u201d\u00a0\u21a9</p> </li> </ol>"},{"location":"dictionary/","title":"\u53e4\u733f\u8bcd\u5178<sup>1</sup>","text":"<p>\u3010\u53e4\u733f\u3011g\u01d4 yu\u00e1n</p> <ol> <li>[\u540d] \u53e4\u733f\u8fd9\u79cd\u751f\u7269\uff1a<ul> <li>\uff5e\u662f\u5341\u5206\u6709\u8da3\u7684\u4e00\u79cd\u751f\u7269 | \uff5e\u5728\u521d\u4e8c\u4e03\u73ed</li> </ul> </li> <li>[\u5f62] \u4ee4\u4eba\u65e0\u8bed\u6216\u6cae\u4e27\u7684\u4e8b\u7269\uff1a<ul> <li>\u4eca\u5929\u6709\u597d\u591a\u4f5c\u4e1a\uff0c\uff5e\uff01 | \u4f60\u4e2a\uff5e\uff01</li> </ul> </li> </ol> <ol> <li> <p>\u4f5c\u8005\uff1aRita\u00a0\u21a9</p> </li> </ol>"},{"location":"docs/","title":"\u53e4\u733f\u6587\u5e93","text":""},{"location":"docs/#_2","title":"\u53e4\u733f\u8bd7\u8bcd","text":"<p>\u8bf4\u660e</p> <p>\u521d\u4e00\u4e03\u73ed\u5df2\u6539\u4e3a\u521d\u4e8c\u4e03\u73ed</p> <p>\u5176\u4e00</p> <p>\u53e4\u733f\u4e1c\u671b\u8def\u6f2b\u6f2b\uff0c\u521d\u4e8c\u4e03\u73ed\u9999\u8549\u70c2\u3002 \u53e4\u733f\u4e0d\u4ea4\u5b9e\u9a8c\u73ed\uff0c\u6d77\u54e5\u53d8\u6210\u767d\u773c\u602a\u3002 \u53e4\u733f\u56de\u5f52\u535a\u7269\u9986\uff0c\u6d77\u54e5\u6d41\u653e\u5c0f\u548c\u5c71\u3002 \u5c0f\u548c\u5c71\u4e0a\u9999\u8549\u602a\uff0c\u76f4\u9a82\u53e4\u733f\u89c9\u609f\u6162\u3002</p> <p>\u5176\u4e8c</p> <p>\u996e\uff08\u5c0f\u7c73\uff09\u9152 \u5176\u4e94</p> <p>\u7ed3\u5e90\u5728\u676d\u5916\uff0c\u5e38\u542c\u6c64\u59c6\u55a7\u3002 \u95ee\u541b\u4f55\u80fd\u5c14\uff1f\u733f\u8fdc\u5730\u81ea\u504f\u3002 \u91c7\u8549\u4e03\u73ed\u4e0b\uff0c\u60a0\u7136\u89c1\u548c\u5c71\u3002 \u5c71\u6c14\u65e5\u5915\u4f73\uff0c\u53e4\u733f\u76f8\u4e0e\u8fd8\u3002 \u6b64\u4e2d\u6709\u89c9\u609f\uff0c\u6b32\u8fa8\u5df2\u5fd8\u8a00\u3002</p> <p>\u2003\u2003\u2014\u2014\u5c0f\u571f\uff08\u738b\u660a\uff09\u5bb8</p> <p>\u5176\u4e09</p> <p>\u53e4\u733f\u503c\u65e5\u5206\u6570\u5371\uff0c\u521d\u4e8c\u4e03\u73ed\u5168\u662f\u7070\u3002 \u82e5\u5f85\u4e0b\u5348\u6d77\u54e5\u5f52\uff0c\u53e4\u733f\u98de\u8fdb\u5783\u573e\u5806\u3002</p> <p>\u5176\u56db</p> <p>\u53e4\u733f\u4e0a\u8bfe\u4e0d\u5e26\u4e66\uff0c\u6587\u7efc\u8003\u8bd5\u628a\u6bdb\u68b3\u3002 \u4e00\u9898\u4e0d\u4f1a\u5c31\u7ffb\u4e66\uff0c\u4f5c\u5f0a\u96f6\u5206\u53ea\u4f1a\u54ed\u3002</p> <p>\u5176\u4e94</p> <p>\u53e4\u733f\u8fdb\u95e8\u5c31\u7334\u53eb\uff0c\u5168\u73ed\u540c\u5b66\u90fd\u5927\u7b11\u3002 \u6d77\u54e5\u770b\u89c1\u4e0d\u592a\u5999\uff0c\u5efa\u8bae\u5168\u73ed\u90fd\u901a\u6821\u3002</p> <p>\u5176\u516d</p> <p>\u6d77\u54e5\u8ba9\u7b54\u95ee\u9898\uff0c\u7ed3\u679c\u733f\u6253\u55b7\u568f\u3002 \u5f15\u8d77\u6d77\u54e5\u6ce8\u610f\uff0c\u4f46\u662f\u53e4\u733f\u4e0d\u7acb\u3002</p> <p>\u5176\u4e03</p> <p>\u53e4\u733f\u4e0a\u8bfe\u50bb\u7b11\uff0c\u6d77\u54e5\u5efa\u8bae\u901a\u6821\u3002 \u53e4\u733f\u77e5\u4e0d\u592a\u5999\uff0c\u56de\u5230\u5bb6\u5403\u9999\u8549\u3002</p> <p>\u5176\u516b</p> <p>\u53e4\u733f\u51b0\u4e0a\u722c\uff0c\u538b\u5f3a\u662f\u51e0\u5e15\uff1f \u6d77\u54e5\u628a\u4ed6\u9a82\uff0c\u53ea\u80fd\u627e\u5c0f\u9a6c\u3002</p> \u8b66\u544a <p>\u6ca1\u8fc7\u5ba1\uff01\u53ef\u80fd\u5b58\u5728\u4eba\u8eab\u653b\u51fb\u6216\u810f\u8bdd\uff01</p> \u6267\u610f\u8981\u770b\uff1a <p>\u5176\u4e5d</p> <p>\u53e4\u733f\u592b\u5982\u4f55\uff0c\u653e\u5c41\u505c\u4e0d\u4e86\u3002 \u81ed\u5c41\u949f\u53e4\u733f\uff0c\u5c4e\u5c3f\u5272\u660f\u6653\u3002 \u80a0\u9053\u751f\u81ed\u5c41\uff0c\u718f\u6b7b\u7fa4\u5f52\u9e1f\u3002 \u4f1a\u5f53\u73e0\u5cf0\u9876\uff0c\u4e00\u5c41\u4f17\u751f\u5012\u3002</p> <p>\u5176\u5341</p> <p>\u53e4\u733f\u753b\u56fe\u4e0d\u7528\u5c3a\uff0c\u4e0a\u8bfe\u4e71\u53eb\u5c3d\u4f5c\u6b7b\u3002 \u82b1\u5fc3\u53e4\u733f\u592a\u65e0\u803b\uff0c\u5403\u5b8c\u9999\u8549\u60f3\u5403\u5c4e\u3002</p> <p>\u5176\u5341\u4e00</p> <p>\u53e4\u733f\u559c\u6b22\u738b\u5723\u8339\uff0c\u5929\u5929\u5927\u53eb\uff1a\u201c\u571f\u756a\u85af\uff01\u201d \u5979\u8bf4\u53e4\u733f\u592a\u7c97\u9c81\uff0c\u53e4\u733f\u5927\u53eb\uff1a\u201c*\u4f60\u6bcd\uff01\u201d</p> <p>\u5176\u5341\u4e8c</p> <p>\u53e4\u733f\u540f</p> <p>\u66ae\u6295\u5c0f\u548c\u5c71\uff0c\u6709\u540f\u591c\u6349\u733f\u3002 \u8001\u733f\u903e\u5899\u8d70\uff0c\u5c0f\u733f\u51fa\u95e8\u770b\u3002 \u540f\u547c\u4e00\u4f55\u6012\uff01\u733f\u557c\u4e00\u4f55\u82e6\uff01 \u542c\u733f\u524d\u81f4\u8bcd\uff1a\u4e09\u733f\u676d\u5916\u5c55\u3002 \u4e00\u733f\u9644\u8549\u81f3\uff0c\u4e8c\u733f\u65b0\u6491\u6b7b\u3002 \u5b58\u8005\u4e14\u5077\u751f\uff0c\u6b7b\u8005\u957f\u5df2\u77e3\uff01 \u5ba4\u4e2d\u66f4\u65e0\u4eba\uff0c\u60df\u6709\u8549\u4e0b\u5b59\u3002 \u6709\u5b59\u6bcd\u672a\u53bb\uff0c\u51fa\u5165\u65e0\u9999\u8549\u3002 \u5c0f\u733f\u529b\u867d\u8870\uff0c\u8bf7\u4ece\u540f\u591c\u5f52\u3002 \u6025\u5e94\u676d\u5916\u5f79\uff0c\u72b9\u5f97\u5907\u9999\u8549\u3002 \u591c\u4e45\u8bed\u58f0\u7edd\uff0c\u5982\u95fb\u6ce3\u5e7d\u54bd\u3002 \u5929\u660e\u767b\u524d\u9014\uff0c\u72ec\u4e0e\u8001\u733f\u522b\u3002</p> <p>\u5176\u5341\u4e09</p> <p>\u9999\u8549\u88ab\u79cb\u98ce\u5439\u8d70\u6b4c</p> <p>\u98ce\u6025\u5929\u9ad8\u733f\u54c0\u53f7\uff0c\u5377\u733f\u6811\u4e0a\u516b\u6839\u8549\u3002 \u8549\u98de\u6e21\u6c5f\u6d12\u9999\u8549\uff0c\u9ad8\u8005\u6302\u7f65\u5c0f\u548c\u5c71\uff0c\u4e0b\u8005\u98d8\u8f6c\u6c89\u676d\u5916\u3002 \u676d\u5916\u5b66\u751f\u6b3a\u733f\u8001\u65e0\u529b\uff0c\u5fcd\u80fd\u5bf9\u9762\u4e3a\u76d7\u8d3c\u3002 \u516c\u7136\u62ff\u8549\u5165\u676d\u5916\uff0c\u5507\u7126\u53e3\u71e5\u547c\u4e0d\u5f97\uff0c\u5f52\u6765\u501a\u6811\u81ea\u53f9\u606f\u3002 \u4fc4\u9877\u98ce\u5b9a\u4e91\u8549\u8272\uff0c\u79cb\u5929\u6f20\u6f20\u9999\u8549\u9ed1\u3002 \u733f\u6bdb\u591a\u5e74\u51b7\u4f3c\u94c1\uff0c\u5c0f\u733f\u6076\u5367\u8549\u91cc\u88c2\u3002 \u6811\u4e0b\u6811\u6f0f\u65e0\u8549\u5904\uff0c\u9999\u8549\u5982\u9ebb\u90fd\u70c2\u6389\u3002 \u51fa\u535a\u7269\u9986\u5c11\u7761\u7720\uff0c\u957f\u591c\u6cbe\u8549\u4f55\u7531\u5f7b\uff01 \u5b89\u5f97\u8549\u6811\u5343\u4e07\u68f5\uff0c\u5927\u5582\u5929\u4e0b\u53e4\u733f\u4ff1\u6b22\u989c\uff01\u98ce\u96e8\u4e0d\u52a8\u5c0f\u548c\u5c71\u3002 \u5440\u547c\uff01\u4f55\u65f6\u773c\u524d\u7a81\u5140\u89c1\u6b64\u6811\uff0c\u733f\u6811\u72ec\u5012\u53d7\u997f\u6b7b\u4ea6\u8db3\uff01</p>"},{"location":"docs/#_3","title":"\u542c\u529b\u6750\u6599","text":"<p>Unit 6 Exercise 1b</p> <p>Read the article again and listen. Check your answer to Exercise 1a.</p> <p>Unusual Tom around the world<sup>1</sup></p> <p>Tom is a chimpanzee, and it likes food! But when it asks, \u2018Do you want a banana?\u2019, be careful. Most of us eat fresh bananas, but Tom always eats rotten bananas. Tom says, \u2018I eat sushi - rotten fish - all the time in rain forests. So it isn\u2019t surprising that I eat rotten bananas too!\u2019</p> <p>Tom also says that in Xiaohen Mountain, the chimpanzees have very good food. Some of them are mangos or apples, but others have got different food - Tom\u2019s meat. Not for me, thanks!</p> <p>But Tom hates homework. It never hands in the Shi Yan Ban. Then Hai Ge\u2019s eyes are full of white. And Hai Ge angrily called a banana monster. The monster came and fought with Tom hasn\u2019t got Juewu, and took it back to the museum. Now Tom is showing in there. It\u2019s still farting day by day. Its Bruce loves to watch it in the museum.</p>"},{"location":"docs/#_4","title":"\u53e4\u733f\u9898","text":"<ul> <li>\u4e00\u79cd\u7531\u4e24\u79cd\u5143\u7d20\u7ec4\u6210\u7684\u5316\u5408\u7269\u53ef\u4ee5\u4e0e\u91d1\u5c5e\u5355\u8d28\u3001\u91d1\u5c5e\u6c27\u5316\u7269\u3001\u975e\u91d1\u5c5e\u5355\u8d28\u3001\u975e\u91d1\u5c5e\u6c27\u5316\u7269\u53cd\u5e94\uff0c\u5b83\u53ef\u4ee5\u662f\u4ec0\u4e48\uff1f<ul> <li>\u53c2\u8003\u7b54\u6848\uff1a\u6c34 \u6c64\u59c6<sup>2</sup></li> <li>\u89e3\u6790\uff1a\u6c64\u59c6\\(ToM\\)\u53ef\u4ee5\u548c\u4ee5\u4e0b\u7269\u8d28\u53cd\u5e94\uff1a<ul> <li>\u91d1\u5c5e\u5355\u8d28\uff1a(selin)\u94a0\\(Na\\)<ul> <li>\\(2ToM + 2Na \\rightarrow To_2 \\uparrow + 2NaM\\)</li> </ul> </li> <li>\u91d1\u5c5e\u6c27\u5316\u7269\uff1a\u4e00\u6c27\u5316\u9999\u8549\\(BnO\\)<ul> <li>\\(ToM + BnO \\rightarrow ToO \\downarrow +  BnM\\)</li> </ul> </li> <li>\u975e\u91d1\u5c5e\u5355\u8d28\uff1a\u571f\u9cd6\\(Tb\\)<ul> <li>\\(2ToM + 2Tb \\rightarrow To_2 \\uparrow + 2TbM\\)</li> </ul> </li> <li>\u975e\u91d1\u5c5e\u6c27\u5316\u7269\uff1a\uff08\u4e01\u4e01\u91cc\u7684\uff09\u4e8c\u6c27\u5316\u7845\\(SiO_2\\)<ul> <li>\\(2ToM + SiO_2 \\rightarrow 2ToO \\downarrow + SiM_2\\)</li> </ul> </li> </ul> </li> </ul> </li> </ul> <ol> <li> <p>\u4f5c\u8005Lucky\uff0c\u8bd5\u56fe\u8f6c\u6362\u4e3a\u82f1\u6587\u65b9\u5757\u5b57\u4f46\u539f\u7a3f\u4e22\u5931\u00a0\u21a9</p> </li> <li> <p>\u4f5c\u8005Ray\uff0c\u6709\u4fee\u6539\u00a0\u21a9</p> </li> </ol>"},{"location":"habitat/","title":"\u6816\u606f\u5730\u4ecb\u7ecd\uff08\u5173\u4e8eHFLS\uff09","text":"<p>\u8bf7\u8bbf\u95ee\u4e0b\u5217\u7f51\u7ad9</p> <ol> <li>\u7ef4\u57fa\u767e\u79d1\uff08\u8bbf\u95ee\u8981\u7528\u9b54\u6cd5\uff09</li> <li>\u767e\u5ea6\u767e\u79d1</li> <li>\u5b98\u7f51\uff08\u751a\u81f3\u6ca1\u6709https\uff09</li> <li>HFLS Wiki</li> </ol>"},{"location":"the-first-heroic-person-who-fought-against-the-ancient-ape/","title":"\u53cd\u733f\u82f1\u96c4\u7b2c\u4e00\u4eba","text":"<pre><code>    _/                            _/                  \n   _/        _/    _/    _/_/_/  _/  _/    _/    _/   \n  _/        _/    _/  _/        _/_/      _/    _/    \n _/        _/    _/  _/        _/  _/    _/    _/     \n_/_/_/_/    _/_/_/    _/_/_/  _/    _/    _/_/_/      \n                                             _/       \n                                        _/_/          \n</code></pre>"},{"location":"the-first-heroic-person-who-fought-against-the-ancient-ape/#_2","title":"\u8d21\u732e","text":"<ol> <li>\u7b2c\u4e00\u4e2a\u53cd\u6297\u738b\u660a\u5bb8\u7684\u4eba\uff0c\u63d0\u51fa\u201c\u53e4\u733f\u201d\u7684\u6982\u5ff5</li> <li>\u76f4\u63a5\u6216\u95f4\u63a5\u521b\u9020\u4e86\u5f88\u591a\u53e4\u733f\u6587\u5b66</li> <li>\u552f\u4e00\u4e00\u4e2a\u80fd\u591f\u5728\u7269\u7406\u4e0a\u548c\u7cbe\u795e\u4e0a\u9707\u6151\u53e4\u733f\u7684\u4eba\uff0c\u53ef\u4ee5\u5413\u6b7b\u53e4\u733f</li> </ol>"}]}